{
	"compilerOptions": {
		"target": "ES2020",
		"module": "Node16",
		"moduleResolution": "Node16",
		"outDir": "dist",
		"rootDir": "src",
		"strict": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true,
		"sourceMap": true,
		"experimentalDecorators": true,
		"useDefineForClassFields": false
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist"]
}

